{
  "name": "pithcopy",
  "version": "1.0.0",
  "description": "Print center management desktop application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "lucide-react": "^0.460.0",
    "framer-motion": "^11.12.0",
    "qrcode": "^1.5.4",
    "pdf-to-printer": "^5.6.0",
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.pithcopy.app",
    "productName": "PıthCopy",
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
